API_KEY=test-key-123

# Google AI Studio / Gemini sales-support agent
GEMINI_API_KEY=replace-with-server-side-key
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite
LLM_PROVIDER=gemini
LLM_TEMPERATURE=0.45

# Lead form email delivery. Put real secrets in Vercel env vars, not in GitHub.
SMTP_HOST=sv-mail4.hostsevenplus.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=clients@pksupplychain.com
SMTP_PASS=replace-with-mailbox-password
MAIL_FROM=PK Supply Chain <clients@pksupplychain.com>
LEAD_TO_EMAIL=pongchai@pksupplychain.com
MAIL_DAILY_LIMIT=2000
MAIL_WARN_THRESHOLD=1800
MAX_LEAD_IMAGE_BYTES=3145728

# Optional: use OpenAI or another OpenAI-compatible provider instead.
# OPENAI_API_KEY=replace-with-openai-key
# OPENAI_MODEL=gpt-5.4-mini
# LLM_API_KEY=replace-with-provider-key
# LLM_BASE_URL=https://api.example.com/v1
